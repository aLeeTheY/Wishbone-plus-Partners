{
    "name": "wishbone-plus-partners",
    "version": "1.0.0",
    "description": "A desktop-focused single-page website built with HTML and Sass, using Alpine.js for collapsible sections and AOS for scroll animations. Features custom CSS transitions and is not optimized for mobile.",
