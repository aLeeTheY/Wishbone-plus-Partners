    "overrides": {
        "browser-sync": {
            "socket.io": {
                "engine.io": {
                    "ws": "^8.17.0"
                },
                "socket.io-adapter": {
                    "ws": "^8.17.0"
                }
            },
            "engine.io-client": {
                "ws": "^8.17.0"
            },
            "send": ">=0.19.0",
            "serve-static": ">=1.16.0"
        }
    },
    "scripts": {
        "__PREPARE__": "",
        "prepare": "husky",
        "__WORKFLOW__": "",
        "clean": "gulp clean --force-clean",
        "dev": "cross-env NODE_ENV=development gulp --i18n",
        "staging": "cross-env NODE_ENV=production gulp prod --staging --i18n",
        "prod": "cross-env NODE_ENV=production gulp prod --i18n --prod-server",
        "start": "npm run dev",
        "build": "cross-env NODE_ENV=production gulp prod --i18n --force-clean",
        "local": "cross-env NODE_ENV=production gulp prod --i18n --local --force-clean",
        "secure": "cross-env NODE_ENV=production gulp prod --i18n --https --force-clean",
        "gh-pages": "cross-env NODE_ENV=production gulp prod --i18n --gh-pages --force-clean",
        "archive": "npm run build && gulp zip",
        "__LINT__": "",
        "lint:ts": "eslint . --max-warnings=0",
        "lint:ts:fix": "eslint . --max-warnings=0 --fix",
        "lint:scss": "stylelint \"**/*.scss\" --max-warnings=0",
        "lint:scss:fix": "stylelint \"**/*.scss\" --max-warnings=0 --fix",
        "lint": "npm-run-all --parallel lint:ts lint:scss",
        "lint:fix": "npm-run-all --parallel lint:ts:fix lint:scss:fix",
        "format": "prettier . --write",
        "__TEST__": "",
        "test:editorconfig": "editorconfig-checker"
    }
}
