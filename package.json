    "homepage": "https://github.com/aLeeTheY/Wishbone-plus-Partners#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/aLeeTheY/Wishbone-plus-Partners.git"
    },
    "bugs": {
        "url": "https://github.com/aLeeTheY/Wishbone-plus-Partners/issues"
    },
    "author": {
        "name": "Vladimir Nikulin",
        "email": "aleethey@gmail.com",
        "url": "https://github.com/aLeeTheY"
    },
    "license": "MIT",
    "type": "module",
    "devDependencies": {
        "@biomejs/biome": "2.4.13",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@commitlint/format": "^20.5.0",
        "@commitlint/types": "^20.5.0",
        "@eslint/compat": "^2.0.5",
        "@eslint/js": "^10.0.1",
        "@ffmpeg-installer/ffmpeg": "^1.1.0",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^25.6.0",
        "chokidar-cli": "^3.0.0",
        "cross-env": "^10.1.0",
        "cssnano": "^7.1.7",
        "cssnano-preset-advanced": "^7.0.15",
        "del": "^8.0.1",
        "editorconfig-checker": "^6.1.1",
        "esbuild": "^0.28.0",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.5.0",
        "gulp": "^5.0.1",
        "gulp-clone": "^2.0.1",
        "gulp-esbuild": "^0.14.1",
        "gulp-file-include": "^2.3.0",
        "gulp-fluent-ffmpeg": "^2.0.0",
        "gulp-html-minifier-terser": "^8.0.0",
        "gulp-if": "^3.0.0",
        "gulp-inject-string": "^1.1.2",
        "gulp-newer": "^1.4.0",
        "gulp-nunjucks": "^6.1.0",
        "gulp-nunjucks-render": "^2.2.3",
        "gulp-plumber": "^1.2.1",
        "gulp-postcss": "^10.0.0",
        "gulp-posthtml": "^3.0.5",
        "gulp-prettier": "^6.0.0",
        "gulp-rename": "^2.1.0",
        "gulp-replace": "^1.1.4",
        "gulp-rev": "^12.0.0",
        "gulp-rev-rewrite": "^6.0.0",
        "gulp-sass": "^6.0.1",
        "gulp-sharp-optimize-images": "^4.0.3",
        "gulp-svg-sprite": "^2.0.3",
        "gulp-svgmin": "^4.1.0",
        "gulp-tap": "^2.0.0",
        "gulp-webp-html-fixed": "^1.0.0",
        "gulp-zip": "^6.1.0",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "lint-staged": "^16.4.0",
        "merge-stream": "^2.0.0",
        "npm-run-all": "^4.1.5",
        "penthouse": "^2.3.3",
        "postcss": "^8.5.10",
        "postcss-cli": "^11.0.1",
        "postcss-preset-env": "^11.2.1",
        "postcss-sort-media-queries": "^6.5.0",
        "posthtml": "^0.16.7",
        "posthtml-include": "^2.0.1",
        "prettier": "3.8.3",
        "prettier-plugin-jinja-template": "^2.1.0",
        "rimraf": "^6.1.3",
        "sass": "^1.99.0",
        "sharp": "^0.34.5",
        "stylelint": "^17.9.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-no-unsupported-browser-features": "^8.1.1",
        "terser": "^5.46.2",
        "ts-node": "^10.9.2",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0",
