<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- * For old Internet Explorer --->
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- * BLOCK APPLE DETECTORS --->
    <meta name="format-detection" content="telephone=no, date=no, address=no, email=no" />

    <!-- * Page title --->
    <title>{{ title }}</title>

    <!-- * Page description --->
    <meta name="description" content="{{ description }}" />

    <!-- * Page favicon --->
    <link href="@meta/favicon.ico" rel="icon" type="image/x-icon" />

    <!-- * 1. Inject critical-css --->
    <!-- ! DO NOT REMOVE THIS COMMENT | CRITICAL CSS PLACEHOLDER --->

    <!-- TODO: test link CSS with preload in head --- 90 performance --->
    <!-- * 2. Import vendors CSS --->
    <link rel="preload" href="https://unpkg.com/aos@next/dist/aos.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />

    <!-- * 3. Import my CSS --->
    <link rel="preload" href="@scss/main.scss" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <!-- * 3.1. Fallback (if JS disable) --->
    <noscript>
        <link rel="stylesheet" href="@scss/main.scss" />
    </noscript>

    <script src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
</head>
